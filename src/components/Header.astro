---
import { site } from "../data/site";
import ThemeToggle from "./ThemeToggle.astro";

const base = import.meta.env.BASE_URL;
const current = Astro.url.pathname.replace(/\/$/, "") || "/";

function href(path: string, external?: boolean) {
  if (external) return path.startsWith("/") ? `${base}${path.slice(1)}` : path;
  const clean = path === "/" ? "" : path.replace(/^\//, "");
  return `${base}${clean}`;
}

function isActive(path: string) {
  const target = href(path).replace(/\/$/, "") || "/";
  return current === target;
}
---

<header class="sticky top-0 z-40 border-b border-zinc-200/70 bg-paper/80 backdrop-blur dark:border-zinc-800 dark:bg-ink/80">
  <div class="mx-auto flex max-w-content flex-wrap items-center justify-between gap-x-4 gap-y-1 px-6 py-3.5 md:px-8">
    <a
      href={href("/")}
      class="font-mono text-[15px] font-semibold tracking-tight text-ink transition-colors hover:text-accent dark:text-zinc-100 dark:hover:text-accent-soft"
      aria-label={site.name}
    >
      {site.brand[0]}<span class="text-accent dark:text-accent-soft">.</span>{site.brand[1]}
    </a>

    <nav class="-mx-2 flex flex-wrap items-center gap-0.5 md:gap-1">
      {
        site.nav.map((item) => (
          <a
            href={href(item.href, item.external)}
            target={item.external ? "_blank" : undefined}
            rel={item.external ? "noopener noreferrer" : undefined}
            class:list={[
              "rounded-md px-2 py-1.5 text-sm font-medium transition-colors md:px-2.5",
              isActive(item.href)
                ? "text-accent dark:text-accent-soft"
                : "text-zinc-600 hover:text-ink dark:text-zinc-400 dark:hover:text-zinc-100",
            ]}
          >
            {item.label}
          </a>
        ))
      }
      <ThemeToggle />
    </nav>
  </div>
</header>
