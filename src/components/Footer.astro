---
import { site } from "../data/site";
import SocialLinks from "./SocialLinks.astro";
const year = new Date().getFullYear();
---
<footer class="border-t border-zinc-200/70 dark:border-zinc-800">
  <div class="mx-auto flex max-w-content flex-col items-start justify-between gap-4 px-6 py-8 md:flex-row md:items-center md:px-8">
    <p class="text-sm text-zinc-500 dark:text-zinc-500">
      © {year} {site.name}. Built with Astro.
    </p>
    <SocialLinks variant="labels" />
  </div>
</footer>
