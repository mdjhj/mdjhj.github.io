---
import { site } from "../data/site";
import Icon from "./Icon.astro";

interface Props {
  title: string;
  authors: string[];
  venue: string;
  year: number;
  status: string;
  links: Record<string, string | undefined>;
}
const { title, authors, venue, year, status, links } = Astro.props;

const statusBadge: Record<string, { label: string; class: string } | undefined> = {
  accepted: {
    label: "Accepted",
    class: "border-emerald-500/30 bg-emerald-500/5 text-emerald-700 dark:text-emerald-400",
  },
  "under-review": {
    label: "Under review",
    class: "border-amber-500/30 bg-amber-500/5 text-amber-700 dark:text-amber-400",
  },
  "in-progress": {
    label: "In progress",
    class: "border-zinc-400/40 bg-zinc-400/5 text-zinc-600 dark:text-zinc-400",
  },
};
const badge = statusBadge[status];

// Bold your own name wherever it appears in the author list.
const me = site.name.split(" ")[0];
const linkList = Object.entries(links).filter(([, v]) => Boolean(v)) as [string, string][];
---
<article class="group row-hover border-b border-zinc-200/70 py-6 dark:border-zinc-800">
  <div class="flex items-baseline justify-between gap-4">
    <h3 class="font-display text-lg font-medium leading-snug">{title}</h3>
    <span class="shrink-0 font-mono text-sm text-zinc-400">{year}</span>
  </div>

  <p class="mt-1.5 text-sm text-zinc-600 dark:text-zinc-400">
    {authors.map((a, i) => (
      <>
        <span class={a.includes(me) ? "font-semibold text-ink dark:text-zinc-100" : ""}>{a}</span>{i < authors.length - 1 ? ", " : ""}
      </>
    ))}
  </p>

  <p class="mt-1 flex flex-wrap items-center gap-2 text-sm italic text-zinc-500">
    {venue}
    {badge && (
      <span class:list={["inline-block rounded-full border px-2 py-0.5 text-xs font-medium not-italic", badge.class]}>
        {badge.label}
      </span>
    )}
  </p>

  {linkList.length > 0 && (
    <div class="mt-3 flex flex-wrap gap-2">
      {linkList.map(([k, v]) => (
        <a href={v} target="_blank" rel="noopener noreferrer"
           class="inline-flex items-center gap-1 rounded border border-zinc-300 px-2 py-0.5 font-mono text-xs font-medium text-zinc-600 transition-colors hover:border-accent hover:text-accent dark:border-zinc-700 dark:text-zinc-400 dark:hover:border-accent-soft dark:hover:text-accent-soft">
          {k.toUpperCase()}
          <Icon name="arrow-up-right" class="h-3 w-3" />
        </a>
      ))}
    </div>
  )}
</article>
