---
import Base from "../layouts/Shell.astro";
const base = import.meta.env.BASE_URL;
---
<Base title="Not found">
  <div class="flex flex-col items-start gap-4 py-16">
    <p class="font-mono text-sm uppercase tracking-[0.2em] text-accent dark:text-accent-soft">404</p>
    <h1 class="font-display text-3xl font-semibold">This page doesn't exist.</h1>
    <a href={base} class="link-underline">Back to home →</a>
  </div>
</Base>
