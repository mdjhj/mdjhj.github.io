---
import Base from "../layouts/Shell.astro";
import SectionHeading from "../components/SectionHeading.astro";
import { Image } from "astro:assets";
import { quotes, galleryCaptions } from "../data/site";

// Every image dropped into src/assets/gallery/ shows up here automatically,
// newest additions wherever their filename sorts (prefix with 01-, 02-, ...
// to control order). Add an optional caption in site.ts → galleryCaptions,
// keyed by filename.
const images = import.meta.glob<{ default: ImageMetadata }>(
  "../assets/gallery/*.{jpg,jpeg,png,webp}",
  { eager: true },
);
const gallery = Object.entries(images)
  .sort(([a], [b]) => a.localeCompare(b, undefined, { numeric: true }))
  .map(([path, mod]) => {
    const file = path.split("/").pop() ?? "";
    return { src: mod.default, file, caption: galleryCaptions[file] };
  });
---
<Base title="Life" description="Beyond academia — trips, photographs, and inspirations.">
  <SectionHeading eyebrow="Beyond academia" title="Life" />

  <p class="mb-12 max-w-prose leading-relaxed text-zinc-700 dark:text-zinc-300">
    Not everything fits in a CV. Away from the lab and the lecture hall, I like to
    travel, take photographs, and collect words worth keeping.
  </p>

  <!-- Quotes & inspirations — cards in a grid, so wide screens aren't wasted -->
  {quotes.length > 0 && (
    <section class="mb-16">
      <h2 class="mb-6 font-display text-xl font-semibold tracking-tight">Words I keep coming back to</h2>
      <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-3">
        {quotes.map((q) => (
          <blockquote class="card flex flex-col justify-between gap-4 border-l-2 border-l-accent/50 p-5 dark:border-l-accent-soft/50">
            <p class="font-display text-lg leading-relaxed text-zinc-700 dark:text-zinc-200">
              “{q.text}”
            </p>
            <footer class="font-mono text-xs text-zinc-400 dark:text-zinc-500">— {q.source}</footer>
          </blockquote>
        ))}
      </div>
    </section>
  )}

  <!-- Photographs — masonry wall: images keep their natural orientation
       (portrait/landscape). Full-width on phones, 2 columns on small
       tablets, 3 on desktop. The caption from galleryCaptions appears as an
       overlay note — always visible on touch screens, revealed on hover on
       desktop. -->
  {gallery.length > 0 ? (
    <section>
      <h2 class="mb-6 font-display text-xl font-semibold tracking-tight">Photographs</h2>
      <div class="columns-1 gap-4 sm:columns-2 lg:columns-3">
        {gallery.map((g) => (
          <figure class="group relative mb-4 break-inside-avoid overflow-hidden rounded-xl ring-1 ring-zinc-200 dark:ring-zinc-800">
            <Image
              src={g.src}
              alt={g.caption ?? g.file}
              widths={[320, 480, 640, 960]}
              sizes="(min-width: 1024px) 33vw, (min-width: 640px) 50vw, 100vw"
              class="w-full transition-transform duration-300 group-hover:scale-[1.03]"
            />
            {g.caption && (
              <figcaption class="pointer-events-none absolute inset-x-0 bottom-0 bg-gradient-to-t from-ink/80 to-transparent px-3.5 pb-3 pt-12 font-mono text-xs leading-relaxed text-white transition-all duration-300 lg:translate-y-2 lg:opacity-0 lg:group-hover:translate-y-0 lg:group-hover:opacity-100">
                {g.caption}
              </figcaption>
            )}
          </figure>
        ))}
      </div>
    </section>
  ) : (
    <section class="max-w-prose">
      <h2 class="mb-3 font-display text-xl font-semibold tracking-tight">Photographs</h2>
      <div class="card p-6">
        <p class="text-sm text-zinc-500 dark:text-zinc-400">
          Coming soon — a few frames from trips and everyday life.
        </p>
      </div>
    </section>
  )}
</Base>
