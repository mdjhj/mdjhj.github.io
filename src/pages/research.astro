---
import Base from "../layouts/Shell.astro";
import SectionHeading from "../components/SectionHeading.astro";
import Icon from "../components/Icon.astro";
import { researchInterests } from "../data/site";

// Edit these blocks to describe your research directions.
const directions = [
  {
    title: "Medical Imaging with Deep Learning",
    body: "Reliable, data-efficient models for diagnostic imaging. My published work covers COVID-19 detection from chest X-rays, diabetic retinopathy grading under severe class imbalance, dental disease classification and detection in OPG X-rays, and interpretable hybrid feature-fusion that holds up across heterogeneous public datasets — with a consistent focus on honest evaluation and generalization.",
  },
  {
    title: "NLP & Large Language Models",
    body: "Applied NLP for low-resource languages such as Bangla, from automated tag recommendation for question-answering platforms to LLM-driven tasks. I am currently developing ideas at the intersection of retrieval-augmented generation and reinforcement learning for trustworthy, evidence-grounded systems.",
  },
  {
    title: "Efficient & Scalable AI",
    body: "Efficient model design for real-world deployment, and how parallel and high-performance computing can support training and serving large-scale models — an emerging direction I aim to pursue during my PhD.",
  },
];
---
<Base title="Research" description="Research directions in deep learning, computer vision, and medical imaging.">
  <SectionHeading eyebrow="What I work on" title="Research" />

  <div class="max-w-3xl space-y-10">
    {directions.map((d) => (
      <section>
        <h2 class="font-display text-xl font-medium">{d.title}</h2>
        <p class="mt-3 leading-relaxed text-zinc-700 dark:text-zinc-300">{d.body}</p>
      </section>
    ))}

    <section>
      <h2 class="mb-3 font-display text-xl font-medium">Interests</h2>
      <ul class="flex flex-wrap gap-2">
        {researchInterests.map((t) => (
          <li class="inline-flex items-center gap-2 rounded-full border border-zinc-300 px-3 py-1 text-sm text-zinc-600 dark:border-zinc-700 dark:text-zinc-400">
            <Icon name={t.icon} class="h-3.5 w-3.5 text-accent dark:text-accent-soft" />
            {t.label}
          </li>
        ))}
      </ul>
    </section>
  </div>
</Base>
